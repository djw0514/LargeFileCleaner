<Window x:Class="LargeFileCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="大文件清理"
        Height="760"
        Width="1180"
        MinHeight="690"
        MinWidth="980"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI"
        Activated="Window_Activated"
        Closing="Window_Closing"
        Closed="Window_Closed">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#DDE3EA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E2E8F0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource BaseButtonStyle}" />

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="大文件清理" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="Windows MVP" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    VerticalAlignment="Center"
                    Background="#ECFDF5"
                    BorderBrush="#A7F3D0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,6">
                <TextBlock x:Name="LogPathTextBlock" Foreground="#047857" FontSize="12" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="扫描目录" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,14,0" />
                    <TextBox x:Name="FolderPathTextBox"
                             Grid.Column="1"
                             IsReadOnly="True"
                             Margin="0,0,10,0" />
                    <Button x:Name="SelectFolderButton"
                            Grid.Column="2"
                            Content="选择目录"
                            Click="SelectFolderButton_Click" />
                </Grid>

                <WrapPanel Grid.Row="1" Margin="0,14,0,0">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="阈值" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,5" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ThresholdTextBox" Width="92" Text="300" />
                            <ComboBox x:Name="ThresholdUnitComboBox" Width="78" Margin="8,0,0,0">
                                <ComboBoxItem Content="MB" Tag="MB" IsSelected="True" />
                                <ComboBoxItem Content="GB" Tag="GB" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="删除方式" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,5" />
                        <ComboBox x:Name="DeleteModeComboBox" Width="148">
                            <ComboBoxItem Content="移动到回收站" Tag="RecycleBin" IsSelected="True" />
                            <ComboBoxItem Content="永久删除" Tag="Permanent" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0" VerticalAlignment="Bottom">
                        <CheckBox x:Name="ExcludeSystemDirsCheckBox"
                                  Content="排除系统目录"
                                  IsChecked="True"
                                  MinHeight="36" />
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0" VerticalAlignment="Bottom">
                        <Button x:Name="ScanButton"
                                Content="开始扫描"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ScanButton_Click" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <Button x:Name="CancelScanButton"
                                Content="取消"
                                IsEnabled="False"
                                Click="CancelScanButton_Click" />
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="过滤" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0" />
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             TextChanged="SearchTextBox_TextChanged" />
                    <CheckBox x:Name="DuplicatesOnlyCheckBox"
                              Grid.Column="2"
                              Content="仅显示重复文件"
                              Margin="16,0,14,0"
                              IsEnabled="False"
                              Checked="DuplicatesOnlyCheckBox_Changed"
                              Unchecked="DuplicatesOnlyCheckBox_Changed" />
                    <Button x:Name="FindDuplicatesButton"
                            Grid.Column="3"
                            Content="查找重复文件"
                            Margin="0,0,10,0"
                            Click="FindDuplicatesButton_Click"
                            ToolTip="仅分析当前扫描结果；按文件主数据流的完整内容精确判定" />
                    <Button x:Name="SelectDuplicateCopiesButton"
                            Grid.Column="4"
                            Content="每组保留一份"
                            IsEnabled="False"
                            Click="SelectDuplicateCopiesButton_Click"
                            ToolTip="每个重复组保留路径排序靠前的一份，并勾选其余副本" />
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,0">
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0" MinWidth="128">
                    <StackPanel>
                        <TextBlock Text="匹配文件" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock x:Name="MatchedCountTextBlock" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0" MinWidth="128">
                    <StackPanel>
                        <TextBlock Text="可见结果" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock x:Name="VisibleCountTextBlock" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0" MinWidth="128">
                    <StackPanel>
                        <TextBlock Text="已选文件" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock x:Name="SelectedCountTextBlock" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" MinWidth="148">
                    <StackPanel>
                        <TextBlock Text="预计释放" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <TextBlock x:Name="SelectedSizeTextBlock" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>

        <DataGrid x:Name="FilesGrid"
                  Grid.Row="3"
                  Margin="0,0,0,14"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  PreviewMouseRightButtonDown="FilesGrid_PreviewMouseRightButtonDown"
                  ContextMenuOpening="FilesGrid_ContextMenuOpening">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="MoveFilesMenuItem"
                              Header="移动所选文件到其他目录..."
                              Click="MoveFilesMenuItem_Click" />
                    <MenuItem x:Name="KeepDuplicateMenuItem"
                              Header="将此文件设为重复组保留项"
                              Click="KeepDuplicateMenuItem_Click" />
                    <Separator x:Name="FilesContextMenuSeparator" />
                    <MenuItem x:Name="OpenContainingFolderMenuItem"
                              Header="打开文件所在目录"
                              Click="OpenContainingFolderMenuItem_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="46" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="重复组保留项若被勾选，删除操作会被阻止；移动操作不受影响"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="文件名" Binding="{Binding Name}" SortMemberPath="Name" Width="220" IsReadOnly="True" />
                <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" SortMemberPath="SizeBytes" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedTime, StringFormat=yyyy-MM-dd HH:mm}" SortMemberPath="ModifiedTime" Width="150" IsReadOnly="True" />
                <DataGridTextColumn Header="类型" Binding="{Binding Extension}" SortMemberPath="Extension" Width="90" IsReadOnly="True" />
                <DataGridTextColumn Header="重复状态" Binding="{Binding DuplicateStatusText}" Width="165" IsReadOnly="True" CanUserSort="False" />
                <DataGridTextColumn Header="完整路径" Binding="{Binding FullPath}" SortMemberPath="FullPath" Width="*" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="StatusTextBlock" TextWrapping="Wrap" />
                    <TextBlock x:Name="ScanStatsTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SelectVisibleButton"
                            Content="全选可见"
                            Margin="0,0,10,0"
                            Click="SelectVisibleButton_Click" />
                    <Button x:Name="ClearSelectionButton"
                            Content="取消选择"
                            Margin="0,0,10,0"
                            Click="ClearSelectionButton_Click" />
                    <Button x:Name="DeleteButton"
                            Content="删除所选"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
